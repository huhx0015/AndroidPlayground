<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.android.recyclerview.RecyclerViewActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/recyclerViewToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/teal_700"
        style="@style/Widget.Material3.Toolbar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/recyclerViewButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/recycler_view"
        android:textColor="@android:color/white"
        android:background="@android:color/holo_red_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/listAdapterButton"
        app:layout_constraintTop_toBottomOf="@+id/recyclerViewToolbar" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/listAdapterButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/list_adapter"
        android:textColor="@android:color/white"
        android:background="@android:color/holo_red_light"
        app:layout_constraintStart_toEndOf="@+id/recyclerViewButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/recyclerViewToolbar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/recyclerViewButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>