<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AndroidPlayground">

        <activity
            android:name=".feature.android.lazylist.LazyListActivity"
            android:exported="false" />

        <activity
            android:name=".feature.android.recyclerview.RecyclerViewActivity"
            android:exported="false"
            android:theme="@style/Theme.AndroidPlayground" />

        <activity
            android:name=".feature.entrance.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidPlayground">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".feature.kotlin.coroutine.CoroutineActivity"
            android:exported="false"
            android:theme="@style/Theme.AndroidPlayground" />

        <activity
            android:name=".feature.kotlin.KotlinTopicActivity"
            android:exported="false"
            android:theme="@style/Theme.AndroidPlayground" />
    </application>

</manifest>